# Telegram Bot Configuration
# Copy this file to .env and fill in your actual values

# Get your bot token from BotFather on Telegram (@BotFather)
# Command: /newbot and follow the instructions
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Your Telegram user ID (the owner who receives startup notifications)
# Get it from @userinfobot on Telegram
OWNER_USER_ID=your_user_id_here

# Path to the SQLite database file
# Leave as-is if you want tasks.db in the project directory
TASK_BOT_DB_PATH=tasks.db
